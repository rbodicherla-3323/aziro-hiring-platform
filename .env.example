# Copy this file to .env and adjust values as needed.
#   cp .env.example .env        (Linux/Mac)
#   copy .env.example .env      (Windows)

# Set to "true" to bypass Microsoft login (auto-login as Dev User)
AUTH_DISABLED=true
# Set to "true" to enable MCQ/Coding webcam/screen/fullscreen proctoring flows
PROCTORING_ENABLED=false

SECRET_KEY=dev-secret-key-change-in-production

# Database (Postgres required)
DATABASE_URL=postgresql://user:password@host:5432/aziro_hiring
# Microsoft Azure AD (for production â€” replace with real values)
AZURE_CLIENT_ID=your-azure-client-id
# Use the secret VALUE from Azure portal, not the Secret ID.
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
# Optional but recommended for VM/proxy deployments:
# Set this to your public callback URL to avoid localhost redirect mismatch.
# Example: https://<vm-host-or-domain>/auth/callback
AZURE_REDIRECT_URI=
# Optional auth extensions:
# Comma-separated extra Microsoft email domains allowed to sign in.
# ALLOWED_LOGIN_DOMAINS=aziro.com,ad.msystechnologies.com
# Comma-separated extra users to auto-allow after Microsoft sign-in.
# DEFAULT_FULL_ACCESS_EMAILS=you@aziro.com,you@ad.msystechnologies.com
# ACCESS_ADMIN_EMAILS=admin1@aziro.com,admin2@ad.msystechnologies.com

# Outbound candidate test-link emails
# EMAIL_PROVIDER:
#   smtp  -> use Office365 SMTP credentials below
#   graph -> use Microsoft Graph with AZURE_* + SENDER_EMAIL
#   graph_delegated -> send as logged-in Microsoft user (/me/sendMail)
#   resend -> use Resend API with RESEND_* below
#   auto  -> try delegated Graph, then Resend, then Graph, then SMTP fallback
EMAIL_PROVIDER=resend

# graph_delegated mode requirements:
#   - AUTH_DISABLED=false (must login via Microsoft)
#   - Azure app delegated scope includes Mail.Send

# Microsoft Graph sender mailbox (UPN/email address)
SENDER_EMAIL=aziro-ai-hiring@aziro.com

# Resend API (recommended for simple local/dev setup)
# Local dev: use onboarding@resend.dev while testing with your own inbox.
# VM/prod: use a verified domain sender, e.g. "Aziro Hiring <noreply@aziro.ai>".
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# Outbound candidate test-link emails (Microsoft Outlook / Office365 SMTP)
# Keep for fallback when EMAIL_PROVIDER=auto or for SMTP mode.
SMTP_ENABLED=true
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=aziro-ai-hiring@aziro.com
SMTP_USERNAME=aziro-ai-hiring@aziro.com
SMTP_PASSWORD=your-mailbox-password

# Optional candidate email validation hardening
# EMAIL_VALIDATE_DOMAIN=true
# EMAIL_VALIDATE_MX=true
# EMAIL_MX_TIMEOUT_SECONDS=3
