# ─── .env.production TEMPLATE ───────────────────────────────────
# Copy this file on the VM as:  .env.production
# Fill in real values. NEVER commit this file to git.
# ─────────────────────────────────────────────────────────────────

# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=0

# Database (also set via docker-compose, but keep here for non-Docker runs)
DATABASE_URL=postgresql://aziro:AziroDb2026@db:5432/aziro_hiring

# AI / Encryption
AI_SETTINGS_MASTER_KEY=change-me-to-a-stable-random-secret
AI_DEFAULT_PROVIDER=gemini
SUMMARY_AI_PROVIDER=
DOCINT_AI_PROVIDER=

# AI / Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# AI / OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# AI / Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Email (SMTP)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@aziro.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@aziro.com

# Azure AD (leave empty or "your-azure-client-id" to auto-enable dev bypass)
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# Auth bypass for testing (set to "true" to skip login)
AUTH_DISABLED=false
